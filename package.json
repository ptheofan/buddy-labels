{
  "name": "buddy-labels",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ptheofan/buddy-labels.git"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "node --env-file-if-exists=.env --watch server/index.mjs",
    "start": "node --env-file-if-exists=.env server/index.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "tsc -b --pretty false",
    "check:release-version": "node scripts/check-release-version.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "opentype.js": "^2.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typeface-roboto": "^1.1.13",
    "vite": "^7.1.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20"
  }
}
